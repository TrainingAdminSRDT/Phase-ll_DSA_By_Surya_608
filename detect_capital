class Solution {
public:
    bool detectCapitalUse(string word) {
        int capitals = 0;

        for (char c : word) {
            if (isupper(c))
                capitals++;
        }

        return capitals == word.size() ||      // ALL CAPS
               capitals == 0 ||                // all lowercase
               (capitals == 1 && isupper(word[0])); // First letter capital
    }
};